generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SubscriptionPage {
  slug            String   @id
  businessName    String   @map("business_name")
  headline        String
  subheadline     String   @default("")
  accentColor     String   @map("accent_color")
  backgroundColor String   @map("background_color")
  currency        String   @default("$")
  checkoutUrl     String   @map("checkout_url")
  walletAddress   String   @default("") @map("wallet_address")
  imageUrl        String?  @map("image_url")
  tiers           Json
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  payments        Payment[]

  @@map("subscription_pages")
}

model Payment {
  id                  String           @id @default(uuid())
  pageSlug            String           @map("page_slug")
  tierId              String           @map("tier_id")
  tierName            String           @map("tier_name")
  payerWallet         String           @map("payer_wallet")
  merchantWallet      String           @map("merchant_wallet")
  amountUsdCents      Int              @map("amount_usd_cents")
  amountUsdcBaseUnits BigInt           @map("amount_usdc_base_units")
  token               String           @default("USDC")
  network             String           @default("solana-mainnet")
  signature           String           @unique
  status              String           @default("confirmed")
  createdAt           DateTime         @default(now()) @map("created_at")
  page                SubscriptionPage @relation(fields: [pageSlug], references: [slug], onDelete: Cascade)

  @@index([pageSlug, createdAt])
  @@map("payments")
}
